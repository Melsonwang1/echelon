      ],
      "id": "21247529-f32c-4823-af2d-e3724d469cfe",
      "name": "calling of ai to direct using qwen"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst contentString = response.choices[0].message.content;\nconst parsed = JSON.parse(contentString);\nconst data = parsed.weekly_intelligence_brief \n  || parsed.monthly_intelligence_brief \n  || parsed;\n\nconst messages = [];\n\n// Message 1: Header + Overview\nlet msg1 = \"\";\nmsg1 += `MONTHLY CUSTOMER INTELLIGENCE BRIEF\\n`;\nmsg1 += `━━━━━━━━━━━━━━━━━━━━\\n\\n`;\nmsg1 += `Overview\\n${data.overview}\\n\\n`;\nmsg1 += `${data.themes.length} themes identified this month\\n`;\nmessages.push({ json: { telegram_message: msg1 } });\n\n// Messages 2+: One per theme\ndata.themes.forEach((theme, i) => {\n  let msg = \"\";\n  msg += `THEME ${i + 1}: ${theme.theme.toUpperCase()} (${theme.ticket_count} tickets)\\n`;\n  msg += `Persona: ${theme.persona}\\n\\n`;\n  msg += `Summary\\n${theme.summary}\\n\\n`;\n  msg += `Recurring Signals\\n`;\n  theme.recurring_signals.forEach(signal => {\n    msg += `• ${signal}\\n`;\n  });\n  msg += `\\nMarketing Opportunity\\n${theme.marketing_opportunity}\\n`;\n  messages.push({ json: { telegram_message: msg } });\n});\n\n// Last message: Recommended actions\nlet msgLast = \"\";\nmsgLast += `RECOMMENDED ACTIONS\\n\\n`;\ndata.recommended_actions.forEach((action, i) => {\n  msgLast += `${i + 1}. ${action}\\n\\n`;\n});\nmessages.push({ json: { telegram_message: msgLast } });\n\nreturn messages;"
      },
