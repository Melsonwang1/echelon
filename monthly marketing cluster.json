    {
      "parameters": {
        "jsCode": "const monthly_themes = $input.first().json.monthly_themes;\nconst system_prompt = \"You are a customer intelligence analyst for Boldr, a Singapore premium watch brand. Your job is to analyse customer enquiry themes accumulated over the past month and produce a strategic marketing brief for the CS and marketing team.\";\nconst user_prompt = \"Here is this month's customer enquiry data grouped by theme: \" + \n  JSON.stringify(monthly_themes) + \n  \" For each theme provide: 1. Theme name and buyer persona 2. Total ticket volume this month 3. Summary of what customers are asking 4. Recurring signals or trends across the month 5. Marketing opportunity with specific recommended action. \" +\n  \"Also include at the top level: \" +\n  \"'overview': a 2-3 sentence executive summary of this month's customer intelligence. \" +\n  \"'recommended_actions': a list of 3-5 top priority actions Boldr should take this month based on all themes combined. \" +\n  \"Respond in JSON format only, no extra text. Use EXACTLY these field names, no variations: \" +\n  \"{ overview, recommended_actions, themes: [{ theme, persona, ticket_count, summary, recurring_signals, marketing_opportunity }] }\";\nreturn [{\n  json: {\n    system_prompt,\n    user_prompt,\n    monthly_themes\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        96
      ],
      "id": "888637fd-f98d-4e3f-8ebe-5bb3472e2807",
      "name": "Code in JavaScript1"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer sk-8365f48a47b84500b6956838bc18b3f7"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"qwen-plus\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": {{JSON.stringify($json.system_prompt)}}\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{JSON.stringify($json.user_prompt)}}\n    }\n  ],\n  \"temperature\": 0.2,\n  \"response_format\": {\n    \"type\": \"json_object\"\n  }\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
