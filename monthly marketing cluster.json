    {
      "parameters": {
        "jsCode": "const kb_rows = $input.first().json.kb_rows;\nconst ticket_rows = $input.first().json.ticket_rows;\n\n// Build a lookup map from ticket_id → buyer_persona\nconst ticketPersonaMap = {};\nfor (const ticket of ticket_rows) {\n  ticketPersonaMap[ticket.ticket_id] = ticket.buyer_persona;\n}\n\n// Fallback persona map by theme\nconst personaMap = {\n  materials: 'health_conscious',\n  sustainability: 'sustainability_advocate',\n  sizing: 'enthusiast_active_outdoor',\n  gifting: 'gifter'\n};\n\nconst grouped = {};\n\nfor (const item of kb_rows) {\n  const theme = item.theme;\n  // Use ticket persona if available, fallback to theme map\n  const persona = ticketPersonaMap[item.source_ticket_id] \n    || personaMap[theme] \n    || 'unknown';\n\n  if (!grouped[theme]) {\n    grouped[theme] = {\n      theme,\n      persona,\n      ticket_count: 0,\n      questions: []\n    };\n  }\n\n  grouped[theme].ticket_count++;\n  grouped[theme].questions.push(item.question);\n}\n\nreturn Object.values(grouped).map(group => ({ json: group }));"
      },
