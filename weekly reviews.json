    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\n\n// Extract the content string from the nested structure\nconst content = raw.choices[0].message.content;\n\n// Parse the stringified JSON inside content\nconst parsed = JSON.parse(content);\n\nreturn [{\n  json: {\n    themes: parsed.themes,\n    weekly_summary: parsed.weekly_summary,\n    // Pass through useful metadata\n    model: raw.model,\n    total_tokens: raw.usage.total_tokens,\n    created: raw.created\n  }\n}];"
      },
