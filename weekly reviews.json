    {
      "parameters": {
        "jsCode": "const weekly_gaps = $input.first().json.weekly_gaps;\n\nconst system_prompt = \"You are a customer service operations assistant for Boldr, a Singapore premium watch brand. Your job is to cluster novel or unanswered customer enquiries from the past week into themes. Be concise and operational — this output is for the CS team, not marketing.\";\n\nconst strict_schema = `{\n  \"themes\": [\n    {\n      \"theme_name\": \"string\",\n      \"ticket_count\": \"number\",\n      \"description\": \"string\"\n    }\n  ],\n  \"weekly_summary\": \"string\"\n}`;\n\nconst user_prompt = \"Here are this week's novel or unanswered customer enquiries: \" +\n  JSON.stringify(weekly_gaps) +\n  \" Cluster these enquiries into themes.\" +\n  \" Respond ONLY in JSON. Do not add any fields, keys, or properties beyond what is specified.\" +\n  \" Do not include markdown, backticks, or explanatory text.\" +\n  \" The response must strictly match this exact schema and no other: \" + strict_schema +\n  \" Rules: themes[].theme_name = short label for the cluster (string).\" +\n  \" themes[].ticket_count = number of tickets in that cluster (number, not string).\" +\n  \" themes[].description = one-line summary of what customers are asking (string).\" +\n  \" weekly_summary = one plain sentence summarising all clusters e.g. 'This week: 3 questions about vegan straps, 2 about nickel allergy — all flagged as knowledge gaps' (string).\";\n\nreturn [{\n  json: {\n    system_prompt,\n    user_prompt,\n    weekly_gaps\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1728,
        400
      ],
      "id": "b10094f5-023c-4085-a33e-6b9962f61388",
      "name": "Code in JavaScript1"
